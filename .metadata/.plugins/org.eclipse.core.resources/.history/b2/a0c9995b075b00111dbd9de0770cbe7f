/*
 	NoticeServiceImpl.java
 	- 공지사항 notice 서비스 구현 클래스
 	- 역할 
 	  공지사항 게시물 등록,수정,삭제
 	  첨부파일 업로드, db저장, 삭제
 	  첨부파일 다운로드 응답 생성
 	  
 	-전체 흐름
 	 Controller → NoticeServiceImpl → NoticeMapper → MyBatis XML / DB  
 	 
 	-파일 관련 작업은 DB 뿐 아니라 서버의 실제 파일 시스템도 함께 처리
 	- 업로드 파일
 	   서버 /uploads/notice 폴더에 저장
 	   파일 경로는 DB 파일 테이블에 저장
 */



package com.doit.app.service;

import java.io.File;

import org.springframework.stereotype.Service;

import com.doit.app.mapper.NoticeMapper;

import jakarta.servlet.ServletContext;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

// @Service
// 스프링에게 이 클래스를 서비스 계층 Bean 으로 등록하라고 전달 
// Controller 에서 NoticeService 타입으로 주입받아 사용할 수 있도록 처리
// @RequiredArgsConstructor 
// final이 붙은 필드들을 생성자 주입받고록 생성자 자동 생성
// @Slf4j 로그 출력을 위한 log 변수 자동 생성 = log.info("", e)와 같은 코드 사용 가능 
@Service
@RequiredArgsConstructor 
@Slf4j 
public class NoticeServiceImpl {
	
	
	// 주요 속성 구성 
	private final NoticeMapper mapper;
	// db 작업을 수행하는 매퍼(Mapper)
	// 공지사항 등록, 수정, 삭제 조회, 파일 정보 저장들을 실제 SQL 과 연결 
	
	private final ServletContext servletContext;
	// 웹 어플리케이션의 실제 서버 경로를 구하기 위해 사용 
	
	// 경로를 가져올수있게 .. 문자열
	private String uploadPath;
	// 첨부파일을 저장할 실제 폴더 경로
	
	public void init() {
		uploadPath = servletContext.getRealPath("/uploads/notice");
		
		File file = new File(uploadPath);
		if (!file.exists()) {
			file.mkdirs();
		}
	}

}
