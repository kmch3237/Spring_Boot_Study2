package com.doit.app.controller;

import java.util.List;

import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;

import com.doit.app.domain.Member;
import com.doit.app.service.MemberService;

import jakarta.servlet.http.HttpServletRequest;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;


@Controller
@RequiredArgsConstructor
@Slf4j
@RequestMapping("/member/*")
public class MemberController {

	// controller에서는 서비스 써야함
	private final MemberService service;
	
	// 클래스에 직접 세터 만들 수 있다 = 롬복으로 세터 구성 가능하다 = autowired로 가능하다
	// 이 방법으로도 가능하다는걸 알아야함
	
	@GetMapping("list") 
	public String list(Model model) // 화면에 뿌려야하니깐 viewresolver model 받음
	{
		try {
			int dataCount = service.dataCount();
			List<Member> list = service.listMember();
			
			model.addAttribute("dataCount", dataCount);
			model.addAttribute("memberList", list);
			
			
		} catch (Exception e) {
			log.info("list : ", e);
		}
		
		return "list";
	}
	
	@GetMapping("add") // 등록폼
	// public 등록 컨트롤러
	public String add() 
	{
		return "add";
		
	}
	
	@PostMapping("add") // 등록 
	public String addSubmit(Member dto, HttpServletRequest req)
	{
		try {
			service.insertMember(dto);
			
		} catch (Exception e) {
			log.info("addSubmit : ", e);
		}
		return "redirect:/member/list";
	}

}
