	// 주요 속성 구성 
	private final NoticeMapper mapper;
	// db 작업을 수행하는 매퍼(Mapper)
	// 공지사항 등록, 수정, 삭제 조회, 파일 정보 저장들을 실제 SQL 과 연결 
	
	private final ServletContext servletContext;
	// 웹 어플리케이션의 실제 서버 경로를 구하기 위해 사용 
	
	// 경로를 가져올수있게 .. 문자열
	private String uploadPath;
	// 첨부파일을 저장할 실제 폴더 경로
	
	// DB 어노테이션이 붙은 메소드는 스프링 빈 생성 후 자동 실행.
	// 즉, NoticeServiceImpl 객체가 생성되고, mapper와 servletContext 주입이 끝난 뒤 
	@PostConstruct
	public void init() {
		uploadPath = servletContext.getRealPath("/uploads/notice");
		// 웹 어플리케이션 기준 /upload/notice 의 실제 서버 파일 경로 구하기.
		// 서버 환경에 따라 c:tomcat\ webapps\ app\ uploads\notice 와 같은 경로가 구성되며,
		// 배포 방식에 따라 다른 실제 경로가 구성된다
		
		File file = new File(uploadPath); // 업로드 경로를 File 객체로 생성 
		if (!file.exists()) {			  // 해당 폴더가 실제 존재하는지 확인하여
			file.mkdirs();				 // 존재하지 않을 경우 경로 포함해서 생성
		}
				
	}

	@Override
	public void insertNotice(Notice dto) throws Exception {
		try {
			mapper.insertNotice(dto);
			// 공지사항 게시물 db에 저장 
			// → 게시물 번호 num이 생성되어 dto에 들어간 후
			//    첨부파일 테이블은 게시물 번호를 참조해야 하므로
			//    먼저 게시물을 저장.
			
			
			// 업로드된 파일 목록이 비어있는지 확인 
			if (!dto.getSelectFile().isEmpty()) {
				insertNoticeFile(dto);
				// 첨부파일이 있으면 파일 저장 및 파일 정보 DB저장 처리 
			}
			
		} catch (Exception e) {
			log.info("insertNotice : " , e);
			
			throw e;
		}
		
	}
	
	//※우리가 자체 메소드 정의 , 내부적으로 오버라이딩 할 거 아님
	// private 으로 구성했으므로 이 클래스 내부에서만 사용할 목적으로 구성
	private void insertNoticeFile(Notice dto) throws Exception {
		
		// 업로드된 파일 목록을 하나씩 반복하며 순환
		// MultipartFile 하나가 업로드 하나를 의미 
	    for (MultipartFile mf : dto.getSelectFile()) {
	        try {
	        	
	        	//파일 객체가 없거나 실제 업로드 파일이 비어있는지 확인 
	            if (mf == null || mf.isEmpty()) {
	                continue;
	                // 이와 같은 상황이면 건너뛰기 
	            }

	            String originalFilename = mf.getOriginalFilename();
	            // 사용자가 업로드한 원본 파일명 가져오기 
	            // ex: ample.pdf
	            
	            String extension = originalFilename.substring(originalFilename.lastIndexOf("."));
	            // 원본 파일명에서 확장자 추출 
	            // 예: apple.pdf → .pdf
	            // 파일명에 . 이 없으면 lastIndextof(".")가 -1(string예외는 -1반환)이 되어 에러발생
	            
	            long fileSize = mf.getSize(); // 업로드된 파일 크기를 바이트 단위로 리턴해줌

	            /*------------------------------------------------
	            =UUID(범용 고유 식별자)
	             - 위치, 장소, 시스템 환경에 상관없이 중복되지 않은 고유한 id를 생성하기 위한 표준 규격
	                → 시스템 간 데이터 충돌 없이 유일한 식별자를 붙여야 할 때 사용하는 도구.
	                
	             - DB의 Primary Key의 값이 고유한 값이 필요한 경우
	               보통은 시퀀스의 값이 1씩 증가하는 방식을 사용한다.
	               하지만 이 방식은 몇 가지 단점이 있다.
	                 - 분산 환경에서의 충돌
	                 - 데이터 예측 가능성
	                 - 데이터 통합의 어려움
	                 이와 같은 문제를 해결하기 위해 UUID를 사용 
	                 UUID는 중앙관리서버없이 전세계 어디에서 생성해도
	                 거의 제로에 가까운 확률로 중복되지 않는 값을 생성한다.  
	            -------------------------------------------------*/
	            UUID uuid = UUID.randomUUID();
	            // randomUUID() → 표준 라이브러리 메소드, Version 4 UUID 생성 
	            // 난수를 기반으로 128비트(16바이트)의 아주 긴 값을 생성하므로
	            // 수학적으로 중복이 발생할 확률이 사실상 없다고 봐도 무방하다.
	            // 보통 32자리 16진수 문자열로 표현된다.
	            
	            
	            
	            long uniqueNumber = Math.abs(uuid.getMostSignificantBits());
	            // UUID의 128비트 값 중 상위 64비트를 가져와서 (→ uuid.getMostSignificants())
	            // 양수의 형태로 사용 (→ Math.abs())
	            
	            String saveFilename = System.currentTimeMillis() + String.valueOf(uniqueNumber) + extension;
	            // 지역에 저장할 파일이름 만들기
	            // 구성 → 현재시간밀리초 + UUID 기반으로 만들어진 숫자 + 확장자
	            // 예 :21335436562455435345.pdf
	            // 원본 파일명 그대로 저장하지 않는 이유는 파일명 충돌을 막기 위함.
	            
	            String pathname = uploadPath + File.separator + saveFilename;
	            // 실제 저장 경로 구성.
	            
	            File f = new File(pathname);
	            mf.transferTo(f);
	            
	            dto.setSaveFilename(saveFilename);
	            dto.setOriginalFilename(originalFilename);
	            dto.setFileSize(fileSize);
	            
	            mapper.insertNotice(dto);

	        } catch (NullPointerException e) {
	            log.info("insertNoticeFile NullPoint : ", e);
	            
	            throw e;
	        }
	        catch (Exception e) {
	        	
	        }
	    }
	}

